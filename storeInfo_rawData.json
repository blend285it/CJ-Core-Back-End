    {
        "id": "773adfc957a60053",
        "type": "function",
        "z": "100e189dadb670c8",
        "name": "JWT Verify",
        "func": "const authHeader = msg.req.headers.authorization;\nif (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n    msg.payload = { error: \"Missing or malformed Authorization header\" }\n    return msg;\n}\n\nconst token = authHeader.split(\" \")[1].replace(/^\"+|\"+$/g, '');\nconst secretKey = env.get(\"JWT\");\n\ntry {\n    const decoded = jwt.verify(token, secretKey);\n    msg.payload = decoded;\n    msg.jwt = decoded;\n} catch (err) {\n    msg.payload = { error: err.message }\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [
            {
                "var": "jwt",
                "module": "jsonwebtoken"
            }
        ],
        "x": 370,
        "y": 140,
        "wires": [
            []
        ]
    },
