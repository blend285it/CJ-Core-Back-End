    {
        "id": "fd1862583c4a2882",
        "type": "function",
        "z": "72deba9627bede6d",
        "g": "63314ec708b215e1",
        "name": "updated",
        "func": "let payload = msg.req.body;\ndelete payload._id;\n\npayload.url = payload.external_ip;\n\nconst { lastModified, createdAt, ...updateFields } = payload;\n\nconst upsert = { upsert: true };\nconst filter = { id: payload.id, mac_address: payload.mac_address, branch_id: payload.branch_id };\nconst data = {\n    $set: updateFields,\n    $currentDate: {\n        lastModified: true\n    }\n}\n\nconst query = [filter, data, upsert];\nmsg.payload = query;\nmsg.collection = \"endpoints\";\nmsg.operation = \"updateOne\";\nreturn msg;",
        "outputs": 1,
        "timeout": "",
