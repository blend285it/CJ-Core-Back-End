    {
        "id": "f98c9f845d5dddbb",
        "type": "function",
        "z": "72deba9627bede6d",
        "g": "63314ec708b215e1",
        "name": "response",
        "func": "\nmsg.payload || [];\n\nswitch (msg.endpoint_type) {\n    case \"store_info\":\n        msg.payload = msg.payload.length > 0 ? msg.payload = { status: 200, message: \"ok\", data: msg.payload } : msg.payload = { status: 404, message: \"Not Found!\" };\n        break;\n    case \"added\":\n        msg.payload = msg.payload.acknowledged ? msg.payload = { status: 200, message: \"ok\" } : msg.payload = { status: 400, message: \"Bad Request!\" }\n        break;\n    case \"updated\" || \"deleted\":\n        msg.payload = msg.payload.acknowledged ? msg.payload = { status: 200, message: \"ok\" } : msg.payload = { status: 400, message: \"Bad Request!\" }\n        break;\n    default:\n        break;\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
