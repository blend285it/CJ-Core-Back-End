        "func": "\nif (msg.mbdata) {\n    context.set(\"rawData\", msg.payload); //tn:\n    return null;\n}\n\nif (msg.topic == \"get\") {\n    let data = context.get(\"rawData\");\n    if (msg.mac) {\n        let perStore = data.filter(fil => fil.mac === msg.mac);\n        msg.payload = perStore.length > 0 ? { status: 200, message: \"ok\", data: perStore[0] } : { status: 204, message: \"No Content\" }\n    } else {\n        msg.payload = data !== undefined ? { status: 200, message: \"ok\", data } : { status: 204, message: \"No Content\" } //tn:\n    }\n    return msg;\n}",
